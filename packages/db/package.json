{
  "name": "@coffeeshop/db",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./types": "./src/types/database.ts",
    "./types/*": "./src/types/*.ts"
  },
